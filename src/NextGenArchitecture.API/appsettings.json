{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/nextgen-architecture-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"],
    "Properties": {
      "Application": "NextGen Architecture API"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=nextgen_architecture;Username=postgres;Password=password;",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Key": "NextGenArchitecture_SuperSecretKey_2024_MustBeAtLeast32Characters!",
    "Issuer": "NextGenArchitecture.API",
    "Audience": "NextGenArchitecture.Client",
    "ExpiryInMinutes": 60
  },
  "ApiSettings": {
    "Title": "NextGen Architecture API",
    "Version": "v1.0",
    "Description": "A next-generation .NET Core architecture for building scalable, maintainable applications",
    "Contact": {
      "Name": "NextGen Architecture Team",
      "Email": "support@nextgenarchitecture.com",
      "Url": "https://nextgenarchitecture.com"
    },
    "License": {
      "Name": "MIT",
      "Url": "https://opensource.org/licenses/MIT"
    }
  },
  "CacheSettings": {
    "DefaultExpirationMinutes": 30,
    "SlidingExpirationMinutes": 10,
    "EnableDistributedCache": true,
    "RedisConfiguration": "localhost:6379"
  },
  "HealthChecks": {
    "UI": {
      "HealthChecksUri": "/health",
      "UIPath": "/health-ui",
      "ApiPath": "/health-api",
      "WebhookPath": "/health-webhooks",
      "EvaluationTimeOnSeconds": 10,
      "MinimumSecondsBetweenFailureNotifications": 60
    }
  },
  "RateLimiting": {
    "EnableRateLimiting": true,
    "PermitLimit": 100,
    "Window": "00:01:00",
    "ReplenishmentPeriod": "00:00:10",
    "TokensPerPeriod": 10,
    "QueueLimit": 10
  },
  "Performance": {
    "EnableRequestLogging": true,
    "EnablePerformanceLogging": true,
    "SlowRequestThresholdMs": 1000,
    "EnableResponseCompression": true,
    "EnableResponseCaching": true
  },
  "Security": {
    "EnableHttpsRedirection": true,
    "EnableHsts": true,
    "HstsMaxAge": 31536000,
    "EnableContentSecurityPolicy": true,
    "EnableReferrerPolicy": true
  },
  "AllowedHosts": "*"
}